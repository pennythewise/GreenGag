# .env.example - Production Configuration Template
# Duplicate this file to .env and fill in your API keys. Never commit .env.

# Core System Orchestration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Remote Sensing & Satellite APIs
PLANET_LABS_API_KEY=your_planet_labs_key_here
GOOGLE_EARTH_ENGINE_CREDENTIALS=your_gee_json_path_here
SENTINEL_HUB_CLIENT_ID=your_sentinel_hub_id_here
SENTINEL_HUB_CLIENT_SECRET=your_sentinel_hub_secret_here

# Financial & External Data
NEWS_API_KEY=your_news_api_key_here
INTERNAL_LEDGER_DB_URL=postgresql://user:password@localhost:5432/ledger_audit

# Supabase (documents, chunks, claims, evidence, media)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# RAG / Embeddings (OpenAI)
# text-embedding-3-large at dimensions=2000 (Supabase HNSW max = 2000 dims)
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=2000
RAG_SIMILARITY_THRESHOLD=0.55
RAG_TOP_K_PER_PILLAR=8
RAG_MAX_CHUNKS_TO_LLM=20

# LLM extraction (OpenAI — temporary; was Claude)
LLM_EXTRACTION_MODEL=gpt-4o

# Runtime
# Set to "mock" to run agents against deterministic fixtures (no external calls).
# Set to "live" to call real external APIs (requires all keys above).
GREENGAG_DATA_MODE=mock
